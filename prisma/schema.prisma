generator client {
  provider = "prisma-client-js"  // <-- Исправлено на правильное имя
  // Строку output мы полностью УДАЛЯЕМ, чтобы не ломать импорты
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  name          String?
  email         String    @unique
  phone         String?
  passwordHash  String?   @map("password_hash")
  emailVerified DateTime?
  image         String?
  role          String    @default("customer")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  // Связь: какие персональные промокоды выданы этому пользователю
  personalPromocodes UserPromocode[]
  // Обратная связь для истории использований
  promocodeUsages    PromocodeUsage[] 
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}
model Product {
  id                Int      @id @default(autoincrement())
  image             String   
  title             String
  description       String
  price             Float
  actionPrice       Float
  quantityInStore   Int
  isHit             Boolean @default(false)
  isAction          Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isDeleted         Boolean @default(false)
  orderProducts     Order_product[] // Связь: один продукт может фигурировать во многих заказах
  // Настройка связи "Один ко многим"
  categoryName    String   
  category        Category @relation(fields: [categoryName], references: [category], onDelete: Cascade, onUpdate: Cascade)
  // Связь: к каким промокодам привязан данный товар
  promocodes      ProductPromocode[]
}

model Category {
  id                 Int      @id @default(autoincrement())  
  category           String @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  // Указываем, что у категории есть массив товаров
  products  Product[] // Prisma автоматически свяжет это поле с моделью Product
}
model Order {
  id        Int      @id @default(autoincrement())
  userId    Int      // Внешний ключ для связи с User
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String
  comment   String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderProducts Order_product[] // Связь: один заказ содержит много записей в Order_product
  // ◄ ДОБАВЛЕННЫЕ ПОЛЯ ДЛЯ АУДИТА СКИДОК (Сохраняются в истории заказа навсегда)
  appliedPromo    String?          // Текст промокода на момент покупки (например, "SUMMER2026")
  discountAmount  Float            @default(0) // Сумма скидки в рублях, которая была вычтена из чека
  // ◄ СВЯЗЬ С ТАБЛИЦЕЙ ИСТОРИИ ИСПОЛЬЗОВАНИЯ ПРОМОКОДОВ
  promocodeUsages PromocodeUsage[]
}
model Order_product {
  id              Int      @id @default(autoincrement())
  productId       Int
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId         Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quantityInOrder Int
  priceAtPurchase Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Promocode {
  id          Int                @id @default(autoincrement())
  code        String             @unique // Например, "SUMMER2026"
  discount    Float              // Размер скидки
  type        String             @default("PERCENT") // "PERCENT" или "FIXED"
  expiresAt   DateTime?          
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  // Связи разделены на независимые таблицы:
  products    ProductPromocode[] // Ограничение по товарам (если пусто — действует на ВСЕ товары)
  users       UserPromocode[]    // Ограничение по юзерам (если пусто — доступен ВСЕМ юзерам)
  usages      PromocodeUsage[]   // История использования (кто и когда применил)
  @@map("promocodes")
}


// 1. Таблица связки: Промокод <-> Товары (Многие-ко-многим)
model ProductPromocode {
  productId   Int
  promocodeId Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  promocode   Promocode @relation(fields: [promocodeId], references: [id], onDelete: Cascade)

  @@id([productId, promocodeId])
  @@map("product_promocodes")
}

// 2. Таблица связки: Промокод <-> Персонально для Юзеров (Многие-ко-многим)
model UserPromocode {
  userId      Int
  promocodeId Int
  assignedAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promocode   Promocode @relation(fields: [promocodeId], references: [id], onDelete: Cascade)

  @@id([userId, promocodeId])
  @@map("user_promocodes")
}

// 3. Таблица истории: Кто, когда и в каком заказе уже использовал промокод
model PromocodeUsage {
  id          Int       @id @default(autoincrement())
  promocodeId Int
  userId      Int
  orderId     Int       // Привязка к конкретному заказу, где была скидка
  usedAt      DateTime  @default(now())
  promocode   Promocode @relation(fields: [promocodeId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("promocode_usages")
}
